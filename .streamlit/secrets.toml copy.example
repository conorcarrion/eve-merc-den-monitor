# Copy to secrets.toml locally, or paste into Streamlit Cloud's
# Settings > Secrets when deploying. Never commit real secrets.toml.

EVE_CLIENT_ID = "your-eve-app-client-id"
EVE_SECRET_KEY = "your-eve-app-secret-key"
EVE_CALLBACK_URL = "https://your-app-name.streamlit.app"
ALLIANCE_ID = "99000000"           # your alliance's numeric ID
DATABASE_URL = "postgresql://user:pass@host/dbname?sslmode=require"